{
  "name": "qanvas5-editor",
  "version": "0.2.0",
  "private": true,
  "author": "zak1726",
  "description": "Desktop-first p5.js-style editor for kdb+/q sketches",
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:zaxiom13/Qanvas5.git"
  },
  "scripts": {
    "start": "node scripts/start-desktop.js",
    "build:web": "vite build",
    "start:web": "npm run build:web && node server.js",
    "start:electrobun": "npm run build:web && npx electrobun dev",
    "test": "node --test --test-concurrency=1 --test-timeout=30000 --test-force-exit",
    "demo:record": "playwright test demo/record-demo.spec.js",
    "demo:record:headed": "playwright test demo/record-demo.spec.js --headed",
    "pack": "npm run build:web && electron-builder --dir",
    "dist": "npm run build:web && electron-builder",
    "start:electron": "npm run build:web && electron .",
    "build:electrobun": "npm run build:web && npx electrobun build"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "monaco-editor": "^0.52.2",
    "p5": "^1.11.10",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.5",
    "electrobun": "^1.15.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "svelte": "^5.53.7",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.qanvas5.studio",
    "productName": "Qanvas5 Studio",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "zaxiom13",
        "repo": "Qanvas5"
      }
    ],
    "files": [
      "electron/**/*",
      "public/**/*",
      "web-dist/**/*",
      "server.js",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "releaseInfo": {
      "releaseName": "Qanvas5 Studio ${version}",
      "releaseNotes": "Desktop release with installers, auto-update metadata, and platform packages."
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "win": {
      "verifyUpdateCodeSignature": true,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    }
  }
}
